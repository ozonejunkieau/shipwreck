<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Shipwreck — Dependency Graph</title>
    <style>
        /* ── Reset & base ─────────────────────────────────────────────── */
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&display=swap');

        :root {
            --radius: 6px;
            --font: "Inter", -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
            --transition: 150ms ease;
            --header-h: 56px;
        }

        /* ── Dark theme (default) ─────────────────────────────────────── */
        :root[data-theme="dark"] {
            --bg: #0f0f0f;
            --surface: #1a1a1a;
            --surface2: #222222;
            --border: #2d2d2d;
            --text: #e5e5e5;
            --text-muted: #9ca3af;
            --accent: #3b82f6;
            --accent-hover: #2563eb;
            --node-base: #374151;
            --node-product: #14532d;
            --node-intermediate: #1e3a5f;
            --node-test: #422006;
            --node-base-border: #6b7280;
            --node-product-border: #22c55e;
            --node-intermediate-border: #3b82f6;
            --node-test-border: #d97706;
            --edge-color: #4b5563;
            --edge-highlight: #3b82f6;
            --tooltip-bg: #1f1f1f;
            --highlight-upstream: #f59e0b;
            --highlight-downstream: #22c55e;
            --highlight-selected: #3b82f6;
            --dimmed-opacity: 0.2;
            --btn-bg: #272727;
            --btn-border: #3d3d3d;
            --btn-text: #e5e5e5;
            --input-bg: #1a1a1a;
            --scrollbar-bg: #1a1a1a;
            --scrollbar-thumb: #3d3d3d;
        }

        /* ── Light theme ──────────────────────────────────────────────── */
        :root[data-theme="light"] {
            --bg: #f9fafb;
            --surface: #ffffff;
            --surface2: #f3f4f6;
            --border: #e5e7eb;
            --text: #111827;
            --text-muted: #6b7280;
            --accent: #2563eb;
            --accent-hover: #1d4ed8;
            --node-base: #e5e7eb;
            --node-product: #dcfce7;
            --node-intermediate: #dbeafe;
            --node-test: #fef3c7;
            --node-base-border: #6b7280;
            --node-product-border: #16a34a;
            --node-intermediate-border: #2563eb;
            --node-test-border: #d97706;
            --edge-color: #9ca3af;
            --edge-highlight: #2563eb;
            --tooltip-bg: #ffffff;
            --highlight-upstream: #d97706;
            --highlight-downstream: #16a34a;
            --highlight-selected: #2563eb;
            --dimmed-opacity: 0.15;
            --btn-bg: #ffffff;
            --btn-border: #d1d5db;
            --btn-text: #374151;
            --input-bg: #ffffff;
            --scrollbar-bg: #f3f4f6;
            --scrollbar-thumb: #d1d5db;
        }

        /* ── Global ───────────────────────────────────────────────────── */
        html, body {
            height: 100%;
            overflow: hidden;
            background: var(--bg);
            color: var(--text);
            font-family: var(--font);
            font-size: 13px;
            line-height: 1.5;
        }

        ::-webkit-scrollbar { width: 6px; background: var(--scrollbar-bg); }
        ::-webkit-scrollbar-thumb { background: var(--scrollbar-thumb); border-radius: 3px; }

        /* ── Layout ───────────────────────────────────────────────────── */
        body {
            display: flex;
            flex-direction: column;
        }

        header {
            height: var(--header-h);
            min-height: var(--header-h);
            background: var(--surface);
            border-bottom: 1px solid var(--border);
            display: flex;
            align-items: center;
            padding: 0 16px;
            gap: 16px;
            z-index: 100;
            flex-shrink: 0;
        }

        main {
            flex: 1;
            position: relative;
            overflow: hidden;
        }

        /* ── Header elements ──────────────────────────────────────────── */
        .logo {
            font-size: 15px;
            font-weight: 600;
            color: var(--text);
            white-space: nowrap;
            letter-spacing: -0.01em;
        }

        .stats {
            display: flex;
            gap: 12px;
            color: var(--text-muted);
            font-size: 12px;
            white-space: nowrap;
        }

        .stats span {
            display: flex;
            align-items: center;
            gap: 4px;
        }

        .stats span::before {
            content: "";
            display: inline-block;
            width: 6px;
            height: 6px;
            border-radius: 50%;
            background: var(--accent);
        }

        .controls {
            display: flex;
            align-items: center;
            gap: 8px;
            margin-left: auto;
            flex-wrap: nowrap;
        }

        /* ── Filter input ─────────────────────────────────────────────── */
        #search {
            background: var(--input-bg);
            border: 1px solid var(--border);
            border-radius: var(--radius);
            color: var(--text);
            font-family: var(--font);
            font-size: 12px;
            height: 30px;
            padding: 0 10px;
            outline: none;
            width: 180px;
            transition: border-color var(--transition);
        }

        #search::placeholder { color: var(--text-muted); }
        #search:focus { border-color: var(--accent); }

        /* ── Buttons ──────────────────────────────────────────────────── */
        button {
            background: var(--btn-bg);
            border: 1px solid var(--btn-border);
            border-radius: var(--radius);
            color: var(--btn-text);
            cursor: pointer;
            font-family: var(--font);
            font-size: 12px;
            height: 30px;
            padding: 0 10px;
            transition: background var(--transition), border-color var(--transition);
            white-space: nowrap;
        }

        button:hover {
            background: var(--surface2);
            border-color: var(--accent);
        }

        /* ── Checkbox labels ──────────────────────────────────────────── */
        label {
            display: flex;
            align-items: center;
            gap: 5px;
            color: var(--text-muted);
            font-size: 12px;
            cursor: pointer;
            white-space: nowrap;
            user-select: none;
        }

        label input[type="checkbox"] {
            accent-color: var(--accent);
            cursor: pointer;
            width: 13px;
            height: 13px;
        }

        /* ── Separator ────────────────────────────────────────────────── */
        .sep {
            width: 1px;
            height: 20px;
            background: var(--border);
            flex-shrink: 0;
        }

        /* ── SVG canvas ───────────────────────────────────────────────── */
        #graph-svg {
            width: 100%;
            height: 100%;
            display: block;
            cursor: grab;
        }

        #graph-svg:active { cursor: grabbing; }

        /* ── dagre-d3 node overrides ──────────────────────────────────── */
        .node rect, .node ellipse, .node polygon {
            fill: var(--surface2) !important;
            stroke: var(--border) !important;
            stroke-width: 1.5px;
            rx: 6;
            ry: 6;
        }

        /* classification-based fills */
        .node-base rect         { fill: var(--node-base) !important; stroke: var(--node-base-border) !important; stroke-dasharray: 6 3; }
        .node-intermediate rect { fill: var(--node-intermediate) !important; stroke: var(--node-intermediate-border) !important; stroke-dasharray: 6 3; }
        .node-product rect      { fill: var(--node-product) !important; stroke: var(--node-product-border) !important; }
        .node-test rect         { fill: var(--node-test) !important; stroke: var(--node-test-border) !important; stroke-dasharray: 3 3; }

        /* highlight states */
        .node.highlight-selected rect { stroke: var(--highlight-selected) !important; stroke-width: 2.5px !important; stroke-dasharray: none !important; }
        .node.highlight-upstream rect { stroke: var(--highlight-upstream) !important; stroke-width: 2px !important; }
        .node.highlight-downstream rect { stroke: var(--highlight-downstream) !important; stroke-width: 2px !important; }
        .node.dimmed { opacity: var(--dimmed-opacity); }

        /* ── Node inner HTML ──────────────────────────────────────────── */
        .node-inner {
            padding: 8px 10px;
            min-width: 120px;
            max-width: 220px;
            pointer-events: none;
        }

        .node-title {
            font-size: 12px;
            font-weight: 600;
            color: var(--text);
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
            margin-bottom: 4px;
            letter-spacing: -0.01em;
        }

        .node-tags {
            display: flex;
            flex-wrap: wrap;
            gap: 3px;
            margin-bottom: 3px;
        }

        .tag {
            background: rgba(59, 130, 246, 0.15);
            border: 1px solid rgba(59, 130, 246, 0.3);
            border-radius: 3px;
            color: var(--accent);
            font-size: 10px;
            padding: 0 4px;
            line-height: 16px;
        }

        :root[data-theme="light"] .tag {
            background: rgba(37, 99, 235, 0.08);
            border-color: rgba(37, 99, 235, 0.25);
            color: var(--accent);
        }

        .crit-badge {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            border-radius: 3px;
            font-size: 10px;
            font-weight: 600;
            padding: 1px 5px;
            color: #fff;
            margin-top: 3px;
        }

        /* ── Edge styles ──────────────────────────────────────────────── */
        .edgePath path {
            stroke: var(--edge-color) !important;
            stroke-width: 1.5px;
            fill: none;
        }

        .edgePath.edge-builds_from path { stroke-dasharray: none; }
        .edgePath.edge-produces path    { stroke-dasharray: 6 3; }
        .edgePath.edge-consumes path    { stroke-dasharray: 2 3; }

        .edgePath.highlight-edge path { stroke: var(--edge-highlight) !important; stroke-width: 2px !important; }
        .edgePath.dimmed-edge { opacity: var(--dimmed-opacity); }

        /* arrowhead */
        .edgePath marker path { fill: var(--edge-color) !important; }
        .edgePath.highlight-edge marker path { fill: var(--edge-highlight) !important; }

        /* ── Tooltip ──────────────────────────────────────────────────── */
        #tooltip {
            position: fixed;
            z-index: 9999;
            background: var(--tooltip-bg);
            border: 1px solid var(--border);
            border-radius: 8px;
            box-shadow: 0 8px 24px rgba(0,0,0,0.4);
            padding: 12px 14px;
            max-width: 320px;
            pointer-events: none;
            transition: opacity 120ms ease;
        }

        #tooltip.hidden { display: none; }

        .tooltip-title {
            font-size: 13px;
            font-weight: 600;
            color: var(--text);
            margin-bottom: 8px;
            word-break: break-all;
        }

        .tooltip-body {
            display: flex;
            flex-direction: column;
            gap: 5px;
        }

        .tt-row {
            display: flex;
            gap: 8px;
            align-items: flex-start;
        }

        .tt-label {
            color: var(--text-muted);
            font-size: 11px;
            min-width: 80px;
            flex-shrink: 0;
        }

        .tt-value {
            color: var(--text);
            font-size: 11px;
            word-break: break-all;
        }

        .tt-badge {
            display: inline-block;
            border-radius: 3px;
            font-size: 10px;
            font-weight: 600;
            padding: 1px 6px;
            color: #fff;
        }

        .tt-tag {
            display: inline-block;
            background: rgba(59,130,246,0.12);
            border: 1px solid rgba(59,130,246,0.25);
            border-radius: 3px;
            color: var(--accent);
            font-size: 10px;
            padding: 0 4px;
            line-height: 16px;
            margin: 1px 1px 0 0;
        }

        .tt-source {
            background: var(--surface2);
            border-radius: 4px;
            padding: 4px 6px;
            font-size: 10px;
            color: var(--text-muted);
            font-family: "JetBrains Mono", "Fira Code", monospace;
            word-break: break-all;
        }

        /* ── Empty state ──────────────────────────────────────────────── */
        #empty-state {
            position: absolute;
            inset: 0;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            color: var(--text-muted);
            gap: 8px;
            pointer-events: none;
        }

        #empty-state.hidden { display: none; }

        /* ── Filter badge ─────────────────────────────────────────────── */
        #filter-info {
            position: absolute;
            bottom: 16px;
            left: 16px;
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: var(--radius);
            padding: 6px 10px;
            font-size: 11px;
            color: var(--text-muted);
            pointer-events: none;
        }

        #filter-info.hidden { display: none; }

        /* ── Legend ───────────────────────────────────────────────────── */
        #legend {
            position: absolute;
            bottom: 16px;
            right: 16px;
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: var(--radius);
            padding: 10px 12px;
            font-size: 11px;
            color: var(--text-muted);
            display: flex;
            flex-direction: column;
            gap: 6px;
        }

        .legend-title {
            font-weight: 600;
            color: var(--text);
            font-size: 11px;
            margin-bottom: 2px;
        }

        .legend-item {
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .legend-line {
            width: 28px;
            height: 2px;
            flex-shrink: 0;
        }

        .legend-swatch {
            width: 12px;
            height: 12px;
            border-radius: 2px;
            flex-shrink: 0;
        }
    </style>
</head>
<body>
    <header>
        <div class="logo">🏴‍☠️ Shipwreck</div>
        <div class="stats">
            <span>{{ total_images }} images</span>
            <span>{{ total_edges }} edges</span>
            <span>{{ graph.generated_at }}</span>
        </div>
        <div class="controls">
            <input type="text" id="search" placeholder="Filter images…" autocomplete="off" />
            <div class="sep"></div>
            <label><input type="checkbox" id="toggle-base" checked> Base</label>
            <label><input type="checkbox" id="toggle-test" checked> Test/CI</label>
            <div class="sep"></div>
            <button id="theme-toggle">☀️ Light</button>
            <button id="reset-zoom">Reset zoom</button>
        </div>
    </header>

    <main>
        <svg id="graph-svg">
            <g id="graph-container"></g>
        </svg>

        <div id="empty-state" class="hidden">
            <span style="font-size:32px">🔍</span>
            <span>No nodes match the current filters</span>
        </div>

        <div id="filter-info" class="hidden"></div>

        <div id="legend">
            <div class="legend-title">Classification</div>
            <div class="legend-item">
                <div class="legend-swatch" style="background:#374151; border:2px dashed #6b7280"></div>
                <span>Base</span>
            </div>
            <div class="legend-item">
                <div class="legend-swatch" style="background:#1e3a5f; border:2px dashed #3b82f6"></div>
                <span>Intermediate</span>
            </div>
            <div class="legend-item">
                <div class="legend-swatch" style="background:#14532d; border:2px solid #22c55e"></div>
                <span>Product</span>
            </div>
            <div class="legend-item">
                <div class="legend-swatch" style="background:#422006; border:2px dotted #d97706"></div>
                <span>Test/CI</span>
            </div>
            <div class="legend-title" style="margin-top:4px">Edges</div>
            <div class="legend-item">
                <div class="legend-line" style="background:#4b5563"></div>
                <span>builds_from</span>
            </div>
            <div class="legend-item">
                <div class="legend-line" style="background:#4b5563; background: repeating-linear-gradient(90deg,#4b5563 0,#4b5563 6px,transparent 6px,transparent 9px)"></div>
                <span>produces</span>
            </div>
            <div class="legend-item">
                <div class="legend-line" style="background: repeating-linear-gradient(90deg,#4b5563 0,#4b5563 2px,transparent 2px,transparent 5px)"></div>
                <span>consumes</span>
            </div>
        </div>
    </main>

    <!-- Tooltip -->
    <div id="tooltip" class="tooltip hidden">
        <div class="tooltip-title"></div>
        <div class="tooltip-body"></div>
    </div>

    <!-- Embedded graph data -->
    <script>
        const GRAPH_DATA = {{ graph_data_json | safe }};
    </script>

    <!-- CDN libraries -->
    <script src="https://cdn.jsdelivr.net/npm/d3@7/dist/d3.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/dagre-d3@0.6.4/dist/dagre-d3.min.js"></script>

    <script>
    (function () {
        "use strict";

        // ── Helpers ──────────────────────────────────────────────────────────
        function escapeHtml(str) {
            if (str == null) return "";
            return String(str)
                .replace(/&/g, "&amp;")
                .replace(/</g, "&lt;")
                .replace(/>/g, "&gt;")
                .replace(/"/g, "&quot;");
        }

        /** Map a criticality score [0,10] → heat colour. */
        function criticalityToColor(score) {
            if (score <= 0)  return null;
            if (score < 2.5) return "#16a34a"; // green
            if (score < 5.0) return "#ca8a04"; // yellow
            if (score < 7.5) return "#ea580c"; // orange
            return "#dc2626";                  // red
        }

        /** Build an adjacency representation from GRAPH_DATA.edges. */
        function buildAdjacency() {
            const downstream = {}; // node → set of nodes it points to
            const upstream   = {}; // node → set of nodes pointing to it
            GRAPH_DATA.nodes.forEach(n => { downstream[n.id] = new Set(); upstream[n.id] = new Set(); });
            GRAPH_DATA.edges.forEach(e => {
                if (downstream[e.source]) downstream[e.source].add(e.target);
                if (upstream[e.target])   upstream[e.target].add(e.source);
            });
            return { downstream, upstream };
        }

        /** BFS: collect all reachable nodes from `start` following `adjMap`. */
        function bfs(start, adjMap) {
            const visited = new Set();
            const queue = [start];
            while (queue.length) {
                const cur = queue.shift();
                if (visited.has(cur)) continue;
                visited.add(cur);
                (adjMap[cur] || new Set()).forEach(n => queue.push(n));
            }
            return visited;
        }

        // ── State ────────────────────────────────────────────────────────────
        const nodeMap = {};
        GRAPH_DATA.nodes.forEach(n => { nodeMap[n.id] = n; });

        const adj = buildAdjacency();

        let selectedNode = null;
        let activeFilters = {
            search: "",
            showBase: true,
            showTest: true,
        };

        // ── Build visible node/edge sets given current filters ───────────────
        function computeVisible() {
            const visibleIds = new Set();

            GRAPH_DATA.nodes.forEach(n => {
                const cls = n.classification || "base";

                // classification toggles
                if (!activeFilters.showBase && cls === "base") return;
                if (!activeFilters.showTest && cls === "test") return;

                // search filter: match against canonical name or label
                const q = activeFilters.search.toLowerCase();
                if (q && !n.canonical.toLowerCase().includes(q) && !n.label.toLowerCase().includes(q)) return;

                visibleIds.add(n.id);
            });

            const visibleEdges = GRAPH_DATA.edges.filter(
                e => visibleIds.has(e.source) && visibleIds.has(e.target)
            );

            return { visibleIds, visibleEdges };
        }

        // ── Render ───────────────────────────────────────────────────────────
        const svgEl  = document.getElementById("graph-svg");
        const svg    = d3.select(svgEl);
        const inner  = d3.select("#graph-container");
        const tooltip = document.getElementById("tooltip");
        const emptyState  = document.getElementById("empty-state");
        const filterInfo  = document.getElementById("filter-info");

        const zoom = d3.zoom()
            .scaleExtent([0.1, 4])
            .on("zoom", e => inner.attr("transform", e.transform));

        svg.call(zoom);

        let currentTransform = d3.zoomIdentity;

        function render() {
            // Clear previous graph
            inner.selectAll("*").remove();
            selectedNode = null;

            const { visibleIds, visibleEdges } = computeVisible();

            // Empty state
            if (visibleIds.size === 0) {
                emptyState.classList.remove("hidden");
                filterInfo.classList.add("hidden");
                return;
            }
            emptyState.classList.add("hidden");

            // Filter info badge
            const totalNodes = GRAPH_DATA.nodes.length;
            if (visibleIds.size < totalNodes) {
                filterInfo.textContent = `Showing ${visibleIds.size} of ${totalNodes} images`;
                filterInfo.classList.remove("hidden");
            } else {
                filterInfo.classList.add("hidden");
            }

            // ── Build dagre graph ─────────────────────────────────────────
            const g = new dagreD3.graphlib.Graph({ compound: false })
                .setGraph({ rankdir: "LR", marginx: 40, marginy: 40, ranksep: 80, nodesep: 30 });
            g.setDefaultEdgeLabel(() => ({}));

            visibleIds.forEach(nid => {
                const node = nodeMap[nid];
                const cls  = node.classification || "base";
                const critColor = criticalityToColor(node.criticality);

                const tagsHtml = (node.tags || []).slice(0, 3)
                    .map(t => `<span class="tag">${escapeHtml(t)}</span>`)
                    .join("");

                const critHtml = (critColor && node.criticality > 0)
                    ? `<div class="crit-badge" style="background:${critColor}">${node.criticality.toFixed(1)}</div>`
                    : "";

                const labelHtml = `<div class="node-inner ${escapeHtml(cls)}">
                    <div class="node-title">${escapeHtml(node.label)}</div>
                    ${tagsHtml ? `<div class="node-tags">${tagsHtml}</div>` : ""}
                    ${critHtml}
                </div>`;

                g.setNode(nid, {
                    labelType: "html",
                    label: labelHtml,
                    class: `node-${cls}`,
                    rx: 6,
                    ry: 6,
                    padding: 0,
                });
            });

            visibleEdges.forEach(edge => {
                g.setEdge(edge.source, edge.target, {
                    class: `edge-${edge.relationship}`,
                    arrowhead: "vee",
                    curve: d3.curveBasis,
                });
            });

            // ── Render with dagre-d3 ──────────────────────────────────────
            const renderFn = new dagreD3.render();
            renderFn(inner, g);

            // ── Fit graph to viewport on first render ─────────────────────
            const svgWidth  = svgEl.clientWidth  || 800;
            const svgHeight = svgEl.clientHeight || 600;
            const graphWidth  = g.graph().width  || 1;
            const graphHeight = g.graph().height || 1;

            const scale = Math.min(
                0.95,
                svgWidth  / (graphWidth  + 80),
                svgHeight / (graphHeight + 80)
            );
            const tx = (svgWidth  - graphWidth  * scale) / 2;
            const ty = (svgHeight - graphHeight * scale) / 2;

            const initialTransform = d3.zoomIdentity.translate(tx, ty).scale(scale);
            svg.call(zoom.transform, initialTransform);

            // ── Event: click to highlight path ────────────────────────────
            inner.selectAll("g.node").on("click", function (event, nodeId) {
                event.stopPropagation();
                if (selectedNode === nodeId) {
                    clearHighlight();
                    selectedNode = null;
                } else {
                    selectedNode = nodeId;
                    highlightPath(nodeId);
                }
            });

            // Click on background → clear
            svg.on("click", () => {
                clearHighlight();
                selectedNode = null;
            });

            // ── Event: hover tooltip ──────────────────────────────────────
            inner.selectAll("g.node")
                .on("mouseover", function (event, nodeId) { showTooltip(event, nodeId); })
                .on("mousemove", function (event)          { moveTooltip(event); })
                .on("mouseout",  function ()               { hideTooltip(); });
        }

        // ── Highlight ────────────────────────────────────────────────────────
        function clearHighlight() {
            inner.selectAll("g.node")
                .classed("highlight-selected",   false)
                .classed("highlight-upstream",   false)
                .classed("highlight-downstream", false)
                .classed("dimmed",               false);

            inner.selectAll("g.edgePath")
                .classed("highlight-edge", false)
                .classed("dimmed-edge",    false);
        }

        function highlightPath(nodeId) {
            clearHighlight();

            const upstreamSet   = bfs(nodeId, adj.upstream);
            const downstreamSet = bfs(nodeId, adj.downstream);
            // Remove the selected node itself from upstream/downstream sets
            upstreamSet.delete(nodeId);
            downstreamSet.delete(nodeId);

            const relevant = new Set([nodeId, ...upstreamSet, ...downstreamSet]);

            inner.selectAll("g.node").each(function (nid) {
                const el = d3.select(this);
                if (nid === nodeId) {
                    el.classed("highlight-selected", true);
                } else if (upstreamSet.has(nid)) {
                    el.classed("highlight-upstream", true);
                } else if (downstreamSet.has(nid)) {
                    el.classed("highlight-downstream", true);
                } else {
                    el.classed("dimmed", true);
                }
            });

            inner.selectAll("g.edgePath").each(function (edgeObj) {
                const el = d3.select(this);
                // edgeObj is a {v, w} object from dagre
                const src = edgeObj.v;
                const tgt = edgeObj.w;
                if (relevant.has(src) && relevant.has(tgt)) {
                    el.classed("highlight-edge", true);
                } else {
                    el.classed("dimmed-edge", true);
                }
            });
        }

        // ── Tooltip ──────────────────────────────────────────────────────────
        function showTooltip(event, nodeId) {
            const node = nodeMap[nodeId];
            if (!node) return;

            const critColor = criticalityToColor(node.criticality);
            const cls = node.classification || "base";

            let body = "";

            // Canonical
            body += `<div class="tt-row">
                <span class="tt-label">Canonical</span>
                <span class="tt-value">${escapeHtml(node.canonical)}</span>
            </div>`;

            // Classification
            body += `<div class="tt-row">
                <span class="tt-label">Class</span>
                <span class="tt-value">${escapeHtml(cls)}</span>
            </div>`;

            // Staleness
            if (node.staleness) {
                body += `<div class="tt-row">
                    <span class="tt-label">Staleness</span>
                    <span class="tt-value">${escapeHtml(node.staleness)}</span>
                </div>`;
            }

            // Criticality
            if (node.criticality > 0 && critColor) {
                body += `<div class="tt-row">
                    <span class="tt-label">Criticality</span>
                    <span class="tt-value">
                        <span class="tt-badge" style="background:${critColor}">${node.criticality.toFixed(2)}</span>
                    </span>
                </div>`;
            }

            // Tags
            if (node.tags && node.tags.length > 0) {
                const tagsHtml = node.tags.map(t => `<span class="tt-tag">${escapeHtml(t)}</span>`).join(" ");
                body += `<div class="tt-row">
                    <span class="tt-label">Tags</span>
                    <span class="tt-value">${tagsHtml}</span>
                </div>`;
            }

            // Sources (up to 3)
            if (node.sources && node.sources.length > 0) {
                const shown = node.sources.slice(0, 3);
                const srcHtml = shown.map(s =>
                    `<div class="tt-source">${escapeHtml(s.repo)} · ${escapeHtml(s.file)}:${s.line}</div>`
                ).join("");
                body += `<div class="tt-row">
                    <span class="tt-label">Sources</span>
                    <span class="tt-value" style="flex:1">${srcHtml}</span>
                </div>`;
                if (node.sources.length > 3) {
                    body += `<div class="tt-row">
                        <span class="tt-label"></span>
                        <span class="tt-value" style="color:var(--text-muted)">+${node.sources.length - 3} more</span>
                    </div>`;
                }
            }

            document.querySelector(".tooltip-title").innerHTML = escapeHtml(node.canonical);
            document.querySelector(".tooltip-body").innerHTML = body;

            moveTooltip(event);
            tooltip.classList.remove("hidden");
        }

        function moveTooltip(event) {
            const pad = 16;
            const tw = tooltip.offsetWidth  || 280;
            const th = tooltip.offsetHeight || 160;
            const vw = window.innerWidth;
            const vh = window.innerHeight;

            let x = event.clientX + pad;
            let y = event.clientY + pad;

            if (x + tw > vw - pad) x = event.clientX - tw - pad;
            if (y + th > vh - pad) y = event.clientY - th - pad;

            tooltip.style.left = `${x}px`;
            tooltip.style.top  = `${y}px`;
        }

        function hideTooltip() {
            tooltip.classList.add("hidden");
        }

        // ── Controls ─────────────────────────────────────────────────────────
        document.getElementById("search").addEventListener("input", function () {
            activeFilters.search = this.value.trim();
            render();
        });

        document.getElementById("toggle-base").addEventListener("change", function () {
            activeFilters.showBase = this.checked;
            render();
        });

        document.getElementById("toggle-test").addEventListener("change", function () {
            activeFilters.showTest = this.checked;
            render();
        });

        document.getElementById("reset-zoom").addEventListener("click", () => {
            // Re-render which auto-fits
            render();
        });

        document.getElementById("theme-toggle").addEventListener("click", function () {
            const root = document.documentElement;
            const isDark = root.getAttribute("data-theme") === "dark";
            root.setAttribute("data-theme", isDark ? "light" : "dark");
            this.textContent = isDark ? "🌙 Dark" : "☀️ Light";
        });

        // ── Initial render ────────────────────────────────────────────────────
        render();
    })();
    </script>
</body>
</html>
